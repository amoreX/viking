generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── NextAuth required models ──

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  githubId          Int?     @unique
  githubUsername     String?  @unique
  bio               String?
  avatarUrl         String?
  githubAccessToken String?
  lastSyncedAt      DateTime?

  accounts      Account[]
  sessions      Session[]
  repos         Repo[]
  scores        Score[]
  snapshots     DailySnapshot[]
  userBadges    UserBadge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── App models ──

model Repo {
  id              String  @id @default(cuid())
  userId          String
  githubId        Int     @unique
  name            String
  fullName        String
  description     String?
  language        String?
  stars           Int     @default(0)
  isPrivate       Boolean @default(false)
  defaultBranch   String  @default("main")
  includedInScoring Boolean @default(true)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pullRequests PullRequest[]
  commits      Commit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PullRequest {
  id           String    @id @default(cuid())
  repoId       String
  githubId     Int       @unique
  number       Int
  title        String
  state        String
  mergedAt     DateTime?
  additions    Int       @default(0)
  deletions    Int       @default(0)
  changedFiles Int       @default(0)
  commitCount  Int       @default(1)

  repo  Repo     @relation(fields: [repoId], references: [id], onDelete: Cascade)
  files PrFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrFile {
  id            String @id @default(cuid())
  pullRequestId String
  filename      String
  status        String
  additions     Int    @default(0)
  deletions     Int    @default(0)
  patch         String?
  isGenerated   Boolean @default(false)

  pullRequest PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
}

model Commit {
  id           String   @id @default(cuid())
  repoId       String
  sha          String   @unique
  message      String
  authoredAt   DateTime
  additions    Int      @default(0)
  deletions    Int      @default(0)
  filesChanged Int      @default(0)

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum ScorePeriod {
  DAILY
  WEEKLY
  ALL_TIME
}

model Score {
  id          String      @id @default(cuid())
  userId      String
  periodType  ScorePeriod
  periodStart DateTime
  periodEnd   DateTime

  outputScore  Float @default(0)
  aiLikelihood Float @default(0)
  vibeScore    Float @default(0)

  computedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodType, periodStart])
}

model DailySnapshot {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  prsCreated  Int      @default(0)
  prsMerged   Int      @default(0)
  commitsCount Int     @default(0)
  additions   Int      @default(0)
  deletions   Int      @default(0)
  vibeScore   Float    @default(0)
  rank        Int?
  streak      Int      @default(0)
  badge       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model Badge {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String
  emoji       String @default("🏆")

  userBadges UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}
